{
  "name": "zuratcul-ui",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "prettier": "prettier --check \"**/*.{ts,js,vue,ejs.t}\" --ignore-path ./.gitignore",
    "prettier:fix": "prettier --write --cache \"**/*.{ts,js,vue}\"",
    "lint": "npx eslint \"**/*.{ts,js,vue}\" --ignore-path .gitignore",
    "lint:fix": "yarn lint --cache --fix",
    "init:git-hooks": "chmod +x .githooks/* && git config core.hooksPath .githooks",
    "init:component": "hygen generator component",
    "story:dev": "start-storybook -p 6006",
    "story:build": "build-storybook"
  },
  "dependencies": {
    "vue": "^3.2.45"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@storybook/addon-actions": "^6.5.16",
    "@storybook/addon-essentials": "^6.5.16",
    "@storybook/addon-interactions": "^6.5.16",
    "@storybook/addon-links": "^6.5.16",
    "@storybook/builder-vite": "^0.4.0",
    "@storybook/testing-library": "^0.0.13",
    "@storybook/vue3": "^6.5.16",
    "@typescript-eslint/eslint-plugin": "^5.48.2",
    "@typescript-eslint/parser": "^5.48.2",
    "@vitejs/plugin-vue": "^4.0.0",
    "babel-loader": "^8.3.0",
    "eslint": "^8.32.0",
    "eslint-plugin-storybook": "^0.6.10",
    "eslint-plugin-vue": "^9.9.0",
    "hygen": "^6.2.11",
    "prettier": "2.8.3",
    "typescript": "^4.9.3",
    "vite": "^4.0.0",
    "vue-loader": "^16.8.3",
    "vue-tsc": "^1.0.11"
  }
}
